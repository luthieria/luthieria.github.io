{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve Portfolio Website",
      "type": "shell",
      "command": "python -m http.server 8085 || py -m http.server 8085 || npx http-server . -p 8085",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
